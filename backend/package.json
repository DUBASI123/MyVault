{
  "name": "my-vault-backend",
  "version": "1.0.0",
  "description": "My Vault REST API — auth, master data, academic content",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch-path=src src/server.js",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "verify:live": "node scripts/verify-live.js",
    "db:docker": "docker compose up -d",
    "db:create": "node scripts/create-db.js"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.0",
    "socket.io": "^4.8.3",
    "twilio": "^5.5.2"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
