PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/myvault_db?schema=public"
PG_DATABASE=myvault_db
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Live SMS — Twilio (global)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Live SMS — Fast2SMS (India) https://www.fast2sms.com
FAST2SMS_API_KEY=

# Live email OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
